<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile for a self-contained, single-file Windows x64 release.
  Usage:
    dotnet publish -p:PublishProfile=Release-win-x64
  Or with explicit version:
    dotnet publish -p:PublishProfile=Release-win-x64 -p:Version=1.2.3
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>

    <!-- Bundle everything (managed + native) into a single .exe -->
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>

    <!-- AOT-friendly ahead-of-time compilation for faster startup -->
    <PublishReadyToRun>true</PublishReadyToRun>

    <PublishDir>bin\Release\publish\</PublishDir>
  </PropertyGroup>
</Project>
