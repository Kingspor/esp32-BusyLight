# ── .NET / C# ────────────────────────────────────────────────────────────────

# Build output — never commit, always regenerated by dotnet build
bin/
obj/

# NuGet packages restored locally (legacy packages/ folder, just in case)
packages/
*.nupkg

# Publish output
publish/

# Visual Studio user-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Test results
TestResults/

# ReSharper
_ReSharper*/
*.DotSettings.user

# Rider
.idea/

# ── Arduino / ESP32 ───────────────────────────────────────────────────────────

# Compiled object and binary files
*.hex
*.elf
*.bin
*.map
*.lst
*.o
*.obj
*.lo
*.slo

# Precompiled headers
*.gch
*.pch

# Arduino / PlatformIO build directories
build/
*.build/
.pio/
.pioenvs/
.piolibdeps/
lib/
libdeps/

# Credentials / secrets — never commit these
secrets.h
credentials.h
config_private.h
wifi_config.h

# ── VS Code ───────────────────────────────────────────────────────────────────

.vscode/
*.code-workspace

# ── Arduino IDE generated files ───────────────────────────────────────────────

*.ino.cpp
*.ino.globals.h

# ── OS files ──────────────────────────────────────────────────────────────────

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor backups ────────────────────────────────────────────────────────────

*~
*.swp
*.swo
*.bak
*.tmp
*.orig

# ── Log files ─────────────────────────────────────────────────────────────────

*.log

# ── Python (falls später genutzt) ─────────────────────────────────────────────

__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
